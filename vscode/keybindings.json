// Place your key bindings in this file to override the defaults
[
    {
        "key": "cmd+t",
        "command": "-workbench.action.showAllSymbols"
    },
    {
        "key": "cmd+t",
        "command": "-workbench.action.browser.newTab",
        "when": "activeEditor == 'workbench.editor.browser'"
    },
    {
        "key": "cmd+t",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },
    {
        "key": "ctrl+`",
        "command": "-workbench.action.terminal.toggleTerminal",
        "when": "terminal.active"
    },
    {
        "key": "cmd+i",
        "command": "workbench.panel.chat",
        "when": "workbench.panel.chat.view.copilot.active"
    },
    {
        "key": "ctrl+cmd+i",
        "command": "-workbench.panel.chat",
        "when": "workbench.panel.chat.view.copilot.active"
    },
    {
        "key": "cmd+o",
        "command": "git.openFile",
        "when": "config.git.enabled && isInDiffEditor && !git.missing && gitOpenRepositoryCount != '0' && resourceScheme =~ /^git$|^file$/"
    },
    {
        "key": "cmd+l cmd+o",
        "command": "-extension.liveServer.goOnline",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+l",
        "command": "-workbench.action.browser.focusUrlInput",
        "when": "activeEditor == 'workbench.editor.browser'"
    },
    {
        "key": "cmd+l cmd+c",
        "command": "-extension.liveServer.goOffline",
        "when": "editorTextFocus"
    }
]